{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "surface": {
      "yard": { "$type": "color", "$value": "#f4f3ef" },
      "panel": { "$type": "color", "$value": "#ffffff" },
      "steel": { "$type": "color", "$value": "#252a2f" },
      "ink": { "$type": "color", "$value": "#090d11" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#151a20" },
      "secondary": { "$type": "color", "$value": "#56524d" },
      "inverse": { "$type": "color", "$value": "#ffffff" }
    },
    "accent": {
      "warning": { "$type": "color", "$value": "#f5c542" },
      "rust": { "$type": "color", "$value": "#d95d25" },
      "route": { "$type": "color", "$value": "#1f6feb" },
      "ok": { "$type": "color", "$value": "#1f9d55" }
    },
    "border": {
      "default": { "$type": "color", "$value": "#d4cec0" },
      "dark": { "$type": "color", "$value": "#424244" }
    }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "6px" },
    "lg": { "$type": "dimension", "$value": "8px" }
  },
  "space": {
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" }
  },
  "shadow": {
    "panel": { "$type": "shadow", "$value": { "color": "#090d111f", "offsetX": "0px", "offsetY": "18px", "blur": "40px", "spread": "0px" } },
    "machine": { "$type": "shadow", "$value": { "color": "#090d112e", "offsetX": "0px", "offsetY": "28px", "blur": "60px", "spread": "0px" } }
  }
}
